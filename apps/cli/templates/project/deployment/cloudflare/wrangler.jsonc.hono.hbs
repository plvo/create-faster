{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "{{#if (isMono)}}{{appName}}{{else}}{{projectName}}{{/if}}",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-12",
  "compatibility_flags": ["nodejs_compat"]{{#if (has "database" "d1")}},
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "{{#if (isMono)}}{{appName}}{{else}}{{projectName}}{{/if}}-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "{{#if (isMono)}}../../packages/db/drizzle{{else}}drizzle{{/if}}"
    }
  ]{{/if}}
}
