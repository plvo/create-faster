{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "{{#if (isMono)}}{{appName}}{{else}}{{projectName}}{{/if}}",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-12",
  // global_fetch_strictly_public routes fetch() through the public internet so OpenNext asset serving avoids Worker subrequest limits
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  }{{#if (has "database" "d1")}},
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "{{#if (isMono)}}{{appName}}{{else}}{{projectName}}{{/if}}-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "drizzle"
    }
  ]{{/if}}
}
