{{#if (or (has "database" "d1") (has "database" "postgres") (has "database" "mysql"))}}
import 'server-only';
import { getCloudflareContext } from '@opennextjs/cloudflare';

export type Env = {
{{#if (has "database" "d1")}}
  DB: D1Database;
{{/if}}
{{#if (or (has "database" "postgres") (has "database" "mysql"))}}
  HYPERDRIVE: Hyperdrive;
{{/if}}
};

export async function getEnv(): Promise<Env> {
  const { env } = await getCloudflareContext({ async: true });
  return {
{{#if (has "database" "d1")}}
    DB: env.DB,
{{/if}}
{{#if (or (has "database" "postgres") (has "database" "mysql"))}}
    HYPERDRIVE: env.HYPERDRIVE,
{{/if}}
  };
}
{{/if}}
