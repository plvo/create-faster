{{{{raw}}}}
set working-directory := 'infra'

init env="dev":
    terraform init -reconfigure -backend-config=backend/{{env}}.hcl -backend-config=backend.secrets.hcl -upgrade -input=false

plan env="dev" *args:
    terraform plan -var="env={{env}}" {{args}}

apply env="dev" *args:
    terraform apply -var="env={{env}}" {{args}}

destroy env="dev" *args:
    terraform destroy -var="env={{env}}" {{args}}

fmt:
    terraform fmt -recursive

validate:
    terraform validate

output *args:
    terraform output {{args}}

state *args:
    terraform state {{args}}
{{{{/raw}}}}
