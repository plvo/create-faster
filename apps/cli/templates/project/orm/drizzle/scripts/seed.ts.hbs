---
mono:
  scope: root
---
{{#if (has "database" "d1")}}
import fs from 'node:fs';
import path from 'node:path';
import { Database } from 'bun:sqlite';
import { drizzle } from 'drizzle-orm/bun-sqlite';
import * as schema from {{#if (isMono)}}'@repo/db/schema'{{else}}'../src/lib/db/schema'{{/if}};
import { postTable, userTable } from {{#if (isMono)}}'@repo/db'{{else}}'../src/lib/db'{{/if}};

function getLocalD1DB(): string | undefined {
  const d1Dir = path.resolve(process.cwd(), '.wrangler/state/v3/d1/miniflare-D1DatabaseObject');
  if (!fs.existsSync(d1Dir)) return undefined;
  const files = fs
    .readdirSync(d1Dir)
    .filter((f) => f.endsWith('.sqlite') && f !== 'metadata.sqlite')
    .map((f) => ({ name: f, mtime: fs.statSync(path.join(d1Dir, f)).mtimeMs }))
    .sort((a, b) => b.mtime - a.mtime);
  return files.length ? path.join(d1Dir, files[0]?.name ?? '') : undefined;
}

const localPath = getLocalD1DB();
if (!localPath) {
  console.error('❌ No local D1 database found. Run `bun run db:migrate:local` first.');
  process.exit(1);
}

const db = drizzle(new Database(localPath), { schema });
{{else}}
{{#if (and (or (has "database" "postgres") (has "database" "mysql")) (has "deployment" "cloudflare"))}}
{{#if (has "database" "postgres")}}
import { drizzle } from 'drizzle-orm/node-postgres';
{{/if}}
{{#if (has "database" "mysql")}}
import { drizzle } from 'drizzle-orm/mysql2';
{{/if}}
import * as schema from {{#if (isMono)}}'@repo/db/schema'{{else}}'../src/lib/db/schema'{{/if}};
import { postTable, userTable } from {{#if (isMono)}}'@repo/db'{{else}}'../src/lib/db'{{/if}};

if (!process.env.DATABASE_URL) {
  throw new Error('DATABASE_URL environment variable is not set');
}

{{#if (has "database" "postgres")}}
const db = drizzle({ schema, connection: { connectionString: process.env.DATABASE_URL } });
{{/if}}
{{#if (has "database" "mysql")}}
const db = drizzle({ schema, mode: 'default', connection: process.env.DATABASE_URL });
{{/if}}
{{else}}
import { db, postTable, userTable } from {{#if (isMono)}}'@repo/db'{{else}}'../src/lib/db'{{/if}};
{{/if}}
{{/if}}

async function seed() {
  console.log('🌱 Seeding database...');

  // Clear existing data
  await db.delete(postTable);
  await db.delete(userTable);

  // Create users
{{#if (has "database" "mysql")}}
  const alice = { id: crypto.randomUUID() };
  const bob = { id: crypto.randomUUID() };
  await db.insert(userTable).values([
    {
      id: alice.id,
      username: 'alice',
      email: 'alice@example.com',
    },
    {
      id: bob.id,
      username: 'bob',
      email: 'bob@example.com',
    },
  ]);
{{else}}
  const [alice, bob] = await db
    .insert(userTable)
    .values([
      {
        username: 'alice',
        email: 'alice@example.com',
      },
      {
        username: 'bob',
        email: 'bob@example.com',
      },
    ])
    .returning();
{{/if}}

  console.log(`✅ Created ${2} users`);

  // Create posts
  await db.insert(postTable).values([
    {
      title: 'Getting Started with Drizzle ORM',
      content: 'Drizzle ORM is a TypeScript-first ORM that provides excellent type safety...',
      published: 'true',
      authorId: alice.id,
    },
    {
      title: 'Building Modern APIs',
      content: 'Modern API development requires careful consideration of many factors...',
      published: 'true',
      authorId: alice.id,
    },
    {
      title: 'Draft: Upcoming Features',
      content: 'This is a draft post about upcoming features...',
      published: 'false',
      authorId: bob.id,
    },
  ]);

  console.log(`✅ Created ${3} posts`);
  console.log('🎉 Seeding completed!');
}

seed()
  .catch((error) => {
    console.error('❌ Seeding failed:', error);
    process.exit(1);
  })
  .finally(() => {
    process.exit(0);
  });
