---
path: src/lib/db/index.ts
---
{{#if (has "database" "d1")}}
import { drizzle } from 'drizzle-orm/d1';
import * as schema from './schema';

export function createDb(d1: D1Database) {
  return drizzle(d1, { schema });
}
export type Database = ReturnType<typeof createDb>;

export * from 'drizzle-orm';
export * from './schema';
export * from './types';
{{else}}
{{#if (and (or (has "database" "postgres") (has "database" "mysql")) (has "deployment" "cloudflare"))}}
{{#if (has "database" "postgres")}}
import { drizzle } from 'drizzle-orm/node-postgres';
import { Pool } from 'pg';
import * as schema from './schema';

export function createDb(hyperdrive: Hyperdrive) {
  const pool = new Pool({
    connectionString: hyperdrive.connectionString,
    maxUses: 1,
  });
  return drizzle({ client: pool, schema });
}
export type Database = ReturnType<typeof createDb>;
{{/if}}
{{#if (has "database" "mysql")}}
import { drizzle } from 'drizzle-orm/mysql2';
import { createConnection } from 'mysql2/promise';
import * as schema from './schema';

export async function createDb(hyperdrive: Hyperdrive) {
  const connection = await createConnection({
    host: hyperdrive.host,
    user: hyperdrive.user,
    password: hyperdrive.password,
    database: hyperdrive.database,
    port: hyperdrive.port,
    disableEval: true,
  });
  return drizzle(connection, { schema, mode: 'default' });
}
export type Database = Awaited<ReturnType<typeof createDb>>;
{{/if}}

export * from 'drizzle-orm';
export * from './schema';
export * from './types';
{{else}}
{{#if (has "database" "postgres")}}
import { drizzle } from 'drizzle-orm/node-postgres';
{{/if}}
{{#if (has "database" "mysql")}}
import { drizzle } from 'drizzle-orm/mysql2';
{{/if}}
{{#if (has "database" "sqlite")}}
{{#if (isMono)}}
import { existsSync } from 'node:fs';
import { dirname, isAbsolute, join } from 'node:path';
{{else}}
import { isAbsolute, join } from 'node:path';
{{/if}}
import { drizzle } from 'drizzle-orm/libsql';
{{/if}}
import * as schema from './schema';

{{#if (has "database" "sqlite")}}
{{#if (isMono)}}
function findMonoRoot(start: string): string {
  let dir = start;
  while (true) {
    if (existsSync(join(dir, 'turbo.json'))) return dir;
    const parent = dirname(dir);
    if (parent === dir) return start;
    dir = parent;
  }
}

{{/if}}
{{/if}}
function createDb() {
  if (!process.env.DATABASE_URL) {
    throw new Error('DATABASE_URL environment variable is not set');
  }
{{#if (has "database" "postgres")}}
  return drizzle({
    schema,
    connection: {
      connectionString: process.env.DATABASE_URL,
      ssl: process.env.NODE_ENV === 'production',
    },
  });
{{/if}}
{{#if (has "database" "mysql")}}
  return drizzle({
    schema,
    mode: 'default',
    connection: process.env.DATABASE_URL,
  });
{{/if}}
{{#if (has "database" "sqlite")}}
  const raw = process.env.DATABASE_URL.replace(/^file:/, '');
{{#if (isMono)}}
  const root = findMonoRoot(process.cwd());
  const url = `file:${isAbsolute(raw) ? raw : join(root, 'packages/db', raw)}`;
{{else}}
  const url = `file:${isAbsolute(raw) ? raw : join(process.cwd(), raw)}`;
{{/if}}
  return drizzle({
    schema,
    connection: { url },
  });
{{/if}}
}

let _db: ReturnType<typeof createDb> | undefined;
export const db = new Proxy({} as ReturnType<typeof createDb>, {
  get(_, prop) {
    if (!_db) _db = createDb();
    return Reflect.get(_db, prop);
  },
});

export * from 'drizzle-orm';
export * from './schema';
export * from './types';
{{/if}}
{{/if}}
