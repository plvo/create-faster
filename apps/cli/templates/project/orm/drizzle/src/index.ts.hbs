---
path: src/lib/db/index.ts
---
{{#if (has "database" "postgres")}}
import { drizzle } from 'drizzle-orm/node-postgres';
{{/if}}
{{#if (has "database" "mysql")}}
import { drizzle } from 'drizzle-orm/mysql2';
{{/if}}
{{#if (has "database" "sqlite")}}
{{#if (isMono)}}
import { existsSync } from 'node:fs';
import { dirname, isAbsolute, join } from 'node:path';
{{else}}
import { isAbsolute, join } from 'node:path';
{{/if}}
import { drizzle } from 'drizzle-orm/libsql';
{{/if}}
import * as schema from './schema';

{{#if (has "database" "sqlite")}}
{{#if (isMono)}}
function findMonoRoot(start: string): string {
  let dir = start;
  while (true) {
    if (existsSync(join(dir, 'turbo.json'))) return dir;
    const parent = dirname(dir);
    if (parent === dir) return start;
    dir = parent;
  }
}

{{/if}}
{{/if}}
function createDb() {
  if (!process.env.DATABASE_URL) {
    throw new Error('DATABASE_URL environment variable is not set');
  }
{{#if (has "database" "postgres")}}
  return drizzle({
    schema,
    connection: {
      connectionString: process.env.DATABASE_URL,
      ssl: process.env.NODE_ENV === 'production',
    },
  });
{{/if}}
{{#if (has "database" "mysql")}}
  return drizzle({
    schema,
    mode: 'default',
    connection: process.env.DATABASE_URL,
  });
{{/if}}
{{#if (has "database" "sqlite")}}
  const raw = process.env.DATABASE_URL.replace(/^file:/, '');
{{#if (isMono)}}
  const root = findMonoRoot(process.cwd());
  const url = `file:${isAbsolute(raw) ? raw : join(root, 'packages/db', raw)}`;
{{else}}
  const url = `file:${isAbsolute(raw) ? raw : join(process.cwd(), raw)}`;
{{/if}}
  return drizzle({
    schema,
    connection: { url },
  });
{{/if}}
}

let _db: ReturnType<typeof createDb> | undefined;
export const db = new Proxy({} as ReturnType<typeof createDb>, {
  get(_, prop) {
    if (!_db) _db = createDb();
    return Reflect.get(_db, prop);
  },
});

export * from 'drizzle-orm';
export * from './schema';
export * from './types';
