'use client';

import { useAccount, useBalance } from 'wagmi';
import { formatEther } from 'viem';
import { useTRPC } from '@/trpc/providers';
import { useMutation, useQuery } from '@tanstack/react-query';
import { useEffect } from 'react';

export default function ProtectedPage() {
  const { address, chain } = useAccount();
  const { data: balance } = useBalance({ address });

  const trpc = useTRPC();
  const { mutate: syncUser } = useMutation(trpc.user.sync.mutationOptions());
  const { data: dbUser } = useQuery(trpc.user.me.queryOptions());

  useEffect(() => {
    syncUser({ walletAddress: address ?? null });
  }, [syncUser, address]);

  return (
    <div className='container mx-auto space-y-6 p-6'>
      <h1 className='text-3xl font-bold'>Dashboard (protected page)</h1>

      <div className='grid gap-4 md:grid-cols-3'>
        <div className='rounded-lg border bg-card p-6'>
          <p className='text-sm text-muted-foreground'>Wallet</p>
          <p className='mt-2 font-mono text-lg'>
            {address ? `${address.slice(0, 6)}...${address.slice(-4)}` : 'Not connected'}
          </p>
        </div>

        <div className='rounded-lg border bg-card p-6'>
          <p className='text-sm text-muted-foreground'>Network</p>
          <p className='mt-2 text-lg'>{chain?.name ?? 'Unknown'}</p>
        </div>

        <div className='rounded-lg border bg-card p-6'>
          <p className='text-sm text-muted-foreground'>Balance</p>
          <p className='mt-2 text-lg'>
            {balance ? `${formatEther(balance.value)} ${balance.symbol}` : '\u2014'}
          </p>
        </div>
      </div>

      {dbUser && (
        <div className='rounded-lg border bg-card p-6'>
          <p className='text-sm text-muted-foreground'>Synced Profile</p>
          <p className='mt-2 font-mono text-sm'>{dbUser.privyId}</p>
        </div>
      )}
    </div>
  );
}
