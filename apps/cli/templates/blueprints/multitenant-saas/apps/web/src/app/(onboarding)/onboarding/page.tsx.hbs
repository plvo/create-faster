'use client';

import { authClient } from '@repo/auth/auth-client';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@repo/ui/components/ui/card';
import { useMutation } from '@tanstack/react-query';
import { useRouter } from 'next/navigation';
import { toast } from 'sonner';
import { z } from 'zod';
import { useAppForm } from '@repo/ui/lib/form';
import { useTRPC } from '@/trpc/providers';

{{{{raw}}}}
function slugify(input: string): string {
  return input
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

const onboardingSchema = z.object({
  name: z.string().min(1, 'Organization name is required'),
  slug: z.string().min(1, 'URL slug is required'),
});

export default function OnboardingPage() {
  const router = useRouter();
  const trpc = useTRPC();
  const createOrg = useMutation(
    trpc.organization.create.mutationOptions({
      onError: (err) => toast.error(err.message ?? 'Failed to create organization'),
    }),
  );

  const form = useAppForm({
    defaultValues: { name: '', slug: '' },
    validators: { onChange: onboardingSchema },
    onSubmit: async ({ value }) => {
      const org = await createOrg.mutateAsync({ name: value.name, slug: value.slug || slugify(value.name) });
      if (org?.id) {
        await authClient.organization.setActive({ organizationId: org.id });
        router.push('/');
      }
    },
  });

  return (
    <div className='flex min-h-screen items-center justify-center p-6'>
      <Card className='w-full max-w-md'>
        <CardHeader>
          <CardTitle>Create your first organization</CardTitle>
          <CardDescription>This is the workspace where your team will collaborate.</CardDescription>
        </CardHeader>
        <CardContent>
          <form
            onSubmit={(e) => {
              e.preventDefault();
              form.handleSubmit();
            }}
            className='space-y-4'
          >
            <form.AppField
              name='name'
              children={(field) => (
                <field.InputField
                  label='Organization name'
                  props={{
                    onChange: (e) => {
                      field.handleChange(e.target.value);
                      if (!form.state.values.slug) form.setFieldValue('slug', slugify(e.target.value));
                    },
                  }}
                />
              )}
            />
            <form.AppField
              name='slug'
              children={(field) => (
                <field.InputField
                  label='URL slug'
                  props={{ onChange: (e) => field.handleChange(slugify(e.target.value)) }}
                />
              )}
            />
            <form.AppForm>
              <form.SubmitButton props={{ className: 'w-full' }}>Create organization</form.SubmitButton>
            </form.AppForm>
          </form>
        </CardContent>
      </Card>
    </div>
  );
}
{{{{/raw}}}}
