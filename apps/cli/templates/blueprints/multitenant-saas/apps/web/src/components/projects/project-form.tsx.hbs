'use client';

import { useMutation, useQueryClient } from '@tanstack/react-query';
import { toast } from 'sonner';
import { z } from 'zod';
import { useAppForm } from '@repo/ui/lib/form';
import { useTRPC } from '@/trpc/providers';

{{{{raw}}}}
const projectSchema = z.object({
  name: z.string().min(1, 'Name is required').max(120),
  description: z.string().max(2000),
  status: z.enum(['active', 'archived']),
});

type ProjectFormProps = {
  mode: 'create' | 'edit';
  initial?: { id: string; name: string; description: string | null; status: 'active' | 'archived' };
  onSuccess?: () => void;
};

export function ProjectForm({ mode, initial, onSuccess }: ProjectFormProps) {
  const trpc = useTRPC();
  const queryClient = useQueryClient();

  const create = useMutation(
    trpc.project.create.mutationOptions({
      onSuccess: () => {
        queryClient.invalidateQueries(trpc.project.list.queryFilter());
        toast.success('Project created');
        onSuccess?.();
      },
      onError: (err) => toast.error(err.message),
    }),
  );
  const update = useMutation(
    trpc.project.update.mutationOptions({
      onSuccess: () => {
        queryClient.invalidateQueries(trpc.project.list.queryFilter());
        queryClient.invalidateQueries(trpc.project.get.queryFilter());
        toast.success('Project updated');
        onSuccess?.();
      },
      onError: (err) => toast.error(err.message),
    }),
  );

  const form = useAppForm({
    defaultValues: {
      name: initial?.name ?? '',
      description: initial?.description ?? '',
      status: initial?.status ?? ('active' as 'active' | 'archived'),
    },
    validators: { onChange: projectSchema },
    onSubmit: async ({ value }) => {
      const description = value.description || null;
      if (mode === 'create') {
        await create.mutateAsync({ name: value.name, description, status: value.status });
      } else if (initial) {
        await update.mutateAsync({ id: initial.id, name: value.name, description, status: value.status });
      }
    },
  });

  return (
    <form
      onSubmit={(e) => {
        e.preventDefault();
        form.handleSubmit();
      }}
      className='space-y-4'
    >
      <form.AppField
        name='name'
        children={(field) => <field.InputField label='Name' props={{ maxLength: 120 }} />}
      />
      <form.AppField
        name='description'
        children={(field) => <field.TextareaField label='Description' props={{ maxLength: 2000, rows: 4 }} />}
      />
      <form.AppField
        name='status'
        children={(field) => <field.SelectField label='Status' options={{ Active: 'active', Archived: 'archived' }} />}
      />
      <form.AppForm>
        <form.SubmitButton props={{ className: 'w-full' }}>
          {mode === 'create' ? 'Create project' : 'Save changes'}
        </form.SubmitButton>
      </form.AppForm>
    </form>
  );
}
{{{{/raw}}}}
