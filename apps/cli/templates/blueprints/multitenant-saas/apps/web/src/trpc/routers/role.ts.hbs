---
path: src/trpc/routers/role.ts
mono:
  scope: pkg
  name: api
  path: src/router/role.ts
---
import { auth } from '@repo/auth/auth';
import { statement } from '@repo/auth/permissions';
{{#if (isMono)}}
import { router } from '../trpc';
import { permissionProcedure } from '../middleware/rbac';
{{else}}
import { router } from '@/trpc/init';
import { permissionProcedure } from '@/trpc/middleware/rbac';
{{/if}}
import { z } from 'zod';

{{{{raw}}}}
const permissionMap = z.record(z.string(), z.array(z.string()));

export const roleRouter = router({
  catalog: permissionProcedure('ac', 'read').query(() => statement),

  list: permissionProcedure('ac', 'read').query(async ({ ctx }) => {
    const result = await auth.api.listOrgRoles({
      headers: ctx.headers,
      query: { organizationId: ctx.orgId },
    });
    return (result ?? []).map((r) => ({ roleName: r.role, permission: r.permission }));
  }),

  create: permissionProcedure('ac', 'create')
    .input(z.object({ role: z.string().min(1).max(60), permission: permissionMap }))
    .mutation(async ({ ctx, input }) => {
      return auth.api.createOrgRole({
        headers: ctx.headers,
        body: { role: input.role, permission: input.permission, organizationId: ctx.orgId },
      });
    }),

  update: permissionProcedure('ac', 'update')
    .input(z.object({ roleName: z.string(), permission: permissionMap }))
    .mutation(async ({ ctx, input }) => {
      return auth.api.updateOrgRole({
        headers: ctx.headers,
        body: { roleName: input.roleName, data: { permission: input.permission }, organizationId: ctx.orgId },
      });
    }),

  delete: permissionProcedure('ac', 'delete')
    .input(z.object({ roleName: z.string() }))
    .mutation(async ({ ctx, input }) => {
      return auth.api.deleteOrgRole({
        headers: ctx.headers,
        body: { roleName: input.roleName, organizationId: ctx.orgId },
      });
    }),
});
{{{{/raw}}}}
