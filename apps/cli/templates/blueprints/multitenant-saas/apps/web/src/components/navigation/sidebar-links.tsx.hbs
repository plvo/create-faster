'use client';

import { authClient } from '@repo/auth/auth-client';
import {
  SidebarGroup,
  SidebarGroupLabel,
  SidebarMenu,
  SidebarMenuButton,
  SidebarMenuItem,
} from '@repo/ui/components/ui/sidebar';
import { HugeiconsIcon } from '@hugeicons/react';
import Link from 'next/link';
import { usePathname } from 'next/navigation';
import { useEffect, useState } from 'react';
import { ROUTES, type RouteProps } from '@/lib/constants';

{{{{raw}}}}
export function SidebarLinks({ role: _role }: { role: string }) {
  const pathname = usePathname();
  const [visibleUrls, setVisibleUrls] = useState<Set<string>>(new Set());

  useEffect(() => {
    let cancelled = false;
    async function resolve() {
      const checks = await Promise.all(
        ROUTES.map(async (route) => {
          if (!route.permission) return route.url;
          const result = await authClient.organization.hasPermission({
            permissions: { [route.permission.resource]: [route.permission.action] },
          });
          return result.data?.success ? route.url : null;
        }),
      );
      if (!cancelled) {
        setVisibleUrls(new Set(checks.filter((u): u is string => u !== null)));
      }
    }
    resolve();
    return () => {
      cancelled = true;
    };
  }, []);

  const visible = ROUTES.filter((r) => !r.permission || visibleUrls.has(r.url));

  const ungrouped = visible.filter((r) => !r.category);
  const grouped = visible.reduce<Record<string, RouteProps[]>>((acc, r) => {
    if (!r.category) return acc;
    (acc[r.category] ??= []).push(r);
    return acc;
  }, {});

  return (
    <>
      <SidebarGroup>
        <SidebarMenu>
          {ungrouped.map((item) => (
            <SidebarMenuItem key={item.url}>
              <SidebarMenuButton
                asChild
                tooltip={item.title}
                isActive={item.url === '/' ? pathname === '/' : pathname.startsWith(item.url)}
              >
                <Link href={item.url}>
                  <HugeiconsIcon icon={item.icon} />
                  <span>{item.title}</span>
                </Link>
              </SidebarMenuButton>
            </SidebarMenuItem>
          ))}
        </SidebarMenu>
      </SidebarGroup>
      {Object.entries(grouped).map(([category, items]) => (
        <SidebarGroup key={category}>
          <SidebarGroupLabel>{category}</SidebarGroupLabel>
          <SidebarMenu>
            {items.map((item) => (
              <SidebarMenuItem key={item.url}>
                <SidebarMenuButton
                  asChild
                  tooltip={item.title}
                  isActive={pathname.startsWith(item.url)}
                >
                  <Link href={item.url}>
                    <HugeiconsIcon icon={item.icon} />
                    <span>{item.title}</span>
                  </Link>
                </SidebarMenuButton>
              </SidebarMenuItem>
            ))}
          </SidebarMenu>
        </SidebarGroup>
      ))}
    </>
  );
}
{{{{/raw}}}}
