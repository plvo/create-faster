import { auth } from '@repo/auth/auth';
import { db } from '@repo/db';
import { project } from '@repo/db/schema';

{{{{raw}}}}
async function main() {
  console.log('Creating users...');

  const owner = await auth.api.signUpEmail({
    body: { email: 'owner@example.com', password: 'owner-password', name: 'Owner Demo' },
  });
  await auth.api.signUpEmail({
    body: { email: 'member@example.com', password: 'member-password', name: 'Member Demo' },
  });

  console.log('Creating organization...');

  const ownerSession = await auth.api.signInEmail({
    body: { email: 'owner@example.com', password: 'owner-password' },
  });
  const ownerHeaders = new Headers({ Authorization: `Bearer ${ownerSession.token}` });

  const org = await auth.api.createOrganization({
    headers: ownerHeaders,
    body: { name: 'Acme Inc.', slug: 'acme' },
  });

  if (!org) {
    throw new Error('Failed to create organization');
  }

  console.log('Inviting and onboarding member...');

  const invite = await auth.api.createInvitation({
    headers: ownerHeaders,
    body: { email: 'member@example.com', role: 'member', organizationId: org.id },
  });

  const memberSession = await auth.api.signInEmail({
    body: { email: 'member@example.com', password: 'member-password' },
  });
  const memberHeaders = new Headers({ Authorization: `Bearer ${memberSession.token}` });

  await auth.api.acceptInvitation({
    headers: memberHeaders,
    body: { invitationId: invite.id },
  });

  console.log('Creating projects...');

  await db.insert(project).values([
    {
      organizationId: org.id,
      createdById: owner.user.id,
      name: 'Onboarding workflow',
      description: 'Set up new customer onboarding',
      status: 'active',
    },
    {
      organizationId: org.id,
      createdById: owner.user.id,
      name: 'Q4 launch',
      description: 'Plan and execute Q4 launch',
      status: 'active',
    },
  ]);

  console.log('Done.');
  console.log('Login as: owner@example.com / owner-password');
  console.log('Or as: member@example.com / member-password');
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});
{{{{/raw}}}}
