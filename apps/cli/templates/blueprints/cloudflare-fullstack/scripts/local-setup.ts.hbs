import { existsSync } from 'node:fs';
import { copyFile, rm } from 'node:fs/promises';

interface Step {
  label: string;
  run: () => Promise<void>;
}

async function sh(command: string[], cwd?: string, env?: Record<string, string>): Promise<void> {
  const proc = Bun.spawn(command, {
    cwd,
    stdio: ['inherit', 'inherit', 'inherit'],
    env: env ? { ...process.env, ...env } : undefined,
  });
  const code = await proc.exited;
  if (code !== 0) throw new Error(`\`${command.join(' ')}\` exited with code ${code}`);
}

async function createEnvFiles(): Promise<void> {
  const glob = new Bun.Glob('**/.env.example');
  for await (const example of glob.scan({ dot: true })) {
    if (example.includes('node_modules')) continue;
    const target = example.slice(0, -'.example'.length);
    if (existsSync(target)) continue;
    await copyFile(example, target);
    console.log(`  created ${target}`);
  }
}

const steps: Step[] = [
  { label: 'Creating .env files from .env.example', run: createEnvFiles },
  { label: 'Resetting local D1 state', run: () => rm('.wrangler/v3/d1', { recursive: true, force: true }) },
  { label: 'Generating Drizzle migrations from schema', run: () => sh(['bun', 'run', 'db:generate']) },
  { label: 'Applying migrations to local D1', run: () => sh(['bun', 'run', 'db:migrate'], undefined, { CI: 'true' }) },
  { label: 'Generating Cloudflare env types', run: () => sh(['bun', 'run', 'cf:typegen'], 'apps/web') },
  { label: 'Seeding local D1 with demo data', run: () => sh(['bun', 'run', 'db:seed', '--fixtures'], undefined, { NODE_ENV: 'development' }) },
];

console.log('Setting up your local environment');
console.log('Note: this resets the local D1 database. Remote data is untouched.\n');

for (const [index, step] of steps.entries()) {
  console.log(`[${index + 1}/${steps.length}] ${step.label}`);
  try {
    await step.run();
  } catch (error) {
    console.error(`\nSetup failed during: ${step.label}`);
    console.error(error instanceof Error ? error.message : error);
    process.exit(1);
  }
}

console.log('\nLocal setup complete. Sign in with a seeded account printed above (e.g. admin@example.com / password), then run `bun dev`.');
