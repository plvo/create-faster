'use client';

import { useMutation, useQueryClient } from '@tanstack/react-query';
import { Check, Copy, Plus } from 'lucide-react';
import { useState } from 'react';
import { toast } from 'sonner';
import { z } from 'zod';
import { roleDefinitions } from '@repo/auth/permissions';
import { Button } from '@repo/ui/components/ui/button';
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
} from '@repo/ui/components/ui/dialog';
import { useAppForm } from '@repo/ui/lib/form';
import { useTRPC } from '@/trpc/providers';

const schema = z.object({
  name: z.string().min(1, 'Name is required').max(64),
  email: z.string().email('Invalid email'),
  role: z.string().min(1),
  firstName: z.string().max(255),
  lastName: z.string().max(255),
  phone: z.string().max(40),
});

const ROLE_OPTIONS = Object.fromEntries(
  Object.keys(roleDefinitions).map((role) => [role.charAt(0).toUpperCase() + role.slice(1), role]),
);

export function CreateUserDialog() {
  const trpc = useTRPC();
  const queryClient = useQueryClient();
  const [open, setOpen] = useState(false);
  const [createdPassword, setCreatedPassword] = useState<string | null>(null);
  const [copied, setCopied] = useState(false);

  const createMutation = useMutation(
    trpc.users.create.mutationOptions({
      onSuccess: ({ password }) => {
        queryClient.invalidateQueries(trpc.users.list.queryFilter());
        setCreatedPassword(password);
      },
      onError: (error) => toast.error(error.message),
    }),
  );

  const form = useAppForm({
    defaultValues: { name: '', email: '', role: 'user', firstName: '', lastName: '', phone: '' },
    validators: { onSubmit: schema },
    onSubmit: async ({ value }) => {
      await createMutation.mutateAsync({
        name: value.name,
        email: value.email,
        role: value.role,
        firstName: value.firstName || undefined,
        lastName: value.lastName || undefined,
        phone: value.phone || undefined,
      });
    },
  });

  function onOpenChange(next: boolean) {
    setOpen(next);
    if (!next) {
      setCreatedPassword(null);
      setCopied(false);
      form.reset();
    }
  }

  async function copyPassword() {
    if (!createdPassword) return;
    await navigator.clipboard.writeText(createdPassword);
    setCopied(true);
    toast.success('Password copied');
  }

  return (
    <Dialog open={open} onOpenChange={onOpenChange}>
      <DialogTrigger asChild>
        <Button>
          <Plus className='size-4' />
          Create user
        </Button>
      </DialogTrigger>
      <DialogContent>
        <DialogHeader>
          <DialogTitle>Create a user</DialogTitle>
          <DialogDescription>A random password is generated and shown once after the account is created.</DialogDescription>
        </DialogHeader>

        {createdPassword ? (
          <div className='space-y-4'>
            <p className='text-sm text-muted-foreground'>
              Account created. Copy the password now — it won&apos;t be shown again.
            </p>
            <div className='flex items-center gap-2 rounded-md border bg-muted/40 p-2'>
              <code className='flex-1 truncate font-mono text-sm'>{createdPassword}</code>
              <Button type='button' variant='outline' size='icon' onClick={copyPassword} aria-label='Copy password'>
                {copied ? <Check className='size-4' /> : <Copy className='size-4' />}
              </Button>
            </div>
            <DialogFooter>
              <Button type='button' onClick={() => onOpenChange(false)}>
                Done
              </Button>
            </DialogFooter>
          </div>
        ) : (
          <form
            onSubmit={(e) => {
              e.preventDefault();
              form.handleSubmit();
            }}
            className='space-y-4'
          >
            <form.AppField name='name'>
              {(f) => <f.InputField label='Display name' props={{ placeholder: 'Jane Doe' }} />}
            </form.AppField>
            <form.AppField name='email'>
              {(f) => <f.InputField label='Email' props={{ type: 'email', placeholder: 'jane@example.com' }} />}
            </form.AppField>
            <form.AppField name='role'>{(f) => <f.SelectField label='Role' options={ROLE_OPTIONS} />}</form.AppField>
            <div className='grid grid-cols-2 gap-3'>
              <form.AppField name='firstName'>{(f) => <f.InputField label='First name' />}</form.AppField>
              <form.AppField name='lastName'>{(f) => <f.InputField label='Last name' />}</form.AppField>
            </div>
            <form.AppField name='phone'>{(f) => <f.InputField label='Phone' />}</form.AppField>
            <DialogFooter>
              <Button type='button' variant='outline' onClick={() => onOpenChange(false)}>
                Cancel
              </Button>
              <form.AppForm>
                <form.SubmitButton>Create user</form.SubmitButton>
              </form.AppForm>
            </DialogFooter>
          </form>
        )}
      </DialogContent>
    </Dialog>
  );
}
{{{{/raw}}}}
