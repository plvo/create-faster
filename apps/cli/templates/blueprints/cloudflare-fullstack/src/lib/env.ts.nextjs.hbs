import 'server-only';
import { getCloudflareContext } from '@opennextjs/cloudflare';

export type Env = {
  DB: D1Database;
  STORAGE: R2Bucket;
};

export async function getEnv(): Promise<Env> {
  const { env } = await getCloudflareContext({ async: true });
  return {
    DB: env.DB,
    STORAGE: env.STORAGE,
  };
}
