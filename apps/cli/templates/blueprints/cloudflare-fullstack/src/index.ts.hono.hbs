---
mono:
  scope: app
  path: src/index.ts
---
import { and, createDb, documentTable, inArray, isNotNull, lt } from '@repo/db';
import app from './app';

interface Env {
  DB: D1Database;
  STORAGE: R2Bucket;
}

async function purgeExpiredDocuments(env: Env): Promise<number> {
  const db = createDb(env.DB);
  const now = new Date();

  const expired = await db
    .select({ id: documentTable.id, r2Key: documentTable.r2Key })
    .from(documentTable)
    .where(and(isNotNull(documentTable.expiresAt), lt(documentTable.expiresAt, now)));

  const purgedIds: string[] = [];
  for (const doc of expired) {
    try {
      await env.STORAGE.delete(doc.r2Key);
      purgedIds.push(doc.id);
    } catch (err) {
      console.error(`[cron] failed to delete R2 object for ${doc.id}:`, err);
    }
  }

  if (purgedIds.length > 0) {
    await db.delete(documentTable).where(inArray(documentTable.id, purgedIds));
  }

  console.log(`[cron] purged ${purgedIds.length} of ${expired.length} expired document(s)`);
  return purgedIds.length;
}

export default {
  fetch: app.fetch,
  async scheduled(_event: ScheduledEvent, env: Env, ctx: ExecutionContext): Promise<void> {
    ctx.waitUntil(purgeExpiredDocuments(env));
  },
};
