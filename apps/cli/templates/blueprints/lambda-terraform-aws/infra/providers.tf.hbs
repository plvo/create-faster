---
mono:
  scope: root
---
locals {
  resource_name = "${var.project_name}-${var.env}"

  common_tags = {
    Project   = var.project_name
    Env       = var.env
    ManagedBy = "terraform"
  }
}

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.0"
    }
  }
  required_version = ">= 1.10.0"
}

provider "aws" {
  region = var.region

  default_tags {
    tags = local.common_tags
  }
}
