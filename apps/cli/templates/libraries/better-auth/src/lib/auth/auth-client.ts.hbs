---
mono:
  scope: pkg
  path: src/auth-client.ts
---
import { inferAdditionalFields } from 'better-auth/client/plugins';
import { createAuthClient } from 'better-auth/react';
{{#if (has "database" "d1")}}
import type { Auth } from './auth';
{{else}}
import type { auth } from './auth';
{{/if}}

export const authClient = createAuthClient({
  plugins: [
    inferAdditionalFields<{{#if (has "database" "d1")}}Auth{{else}}typeof auth{{/if}}>(), // https://www.better-auth.com/docs/concepts/typescript#inferring-additional-fields-on-client
  ],
});
