---
deploymentPath:
  cloudflare: src/middleware.ts
---
{{#if (hasLibrary "evlog")}}
import type { NextRequest } from 'next/server';
import { evlogMiddleware } from 'evlog/next';
{{else}}
import { type NextRequest, NextResponse } from 'next/server';
{{/if}}
{{#if (hasLibrary "better-auth")}}
import { headers } from 'next/headers';
{{#if (isMono)}}
import { auth } from '@repo/auth/auth';
{{else}}
import { auth } from '@/lib/auth/auth';
{{/if}}
{{/if}}

{{#if (hasLibrary "evlog")}}
const withEvlog = evlogMiddleware();
{{/if}}

export default async function {{#if (has "deployment" "cloudflare")}}middleware{{else}}proxy{{/if}}(request: NextRequest) {
  const { pathname } = request.nextUrl;

  {{#if (hasLibrary "better-auth")}}
  const session = await auth.api.getSession({
    headers: await headers(),
  });

  console.log(`{{#if (has "deployment" "cloudflare")}}MIDDLEWARE{{else}}PROXY{{/if}} "${pathname}" | "${session ? session.user.id : 'X'}"`);
  {{else}}
  console.log(`{{#if (has "deployment" "cloudflare")}}MIDDLEWARE{{else}}PROXY{{/if}} "${pathname}"`);
  {{/if}}

  {{#if (hasLibrary "evlog")}}
  return await withEvlog(request);
  {{else}}
  return NextResponse.next();
  {{/if}}
}

export const config = {
  matcher: [
    // Exclude API routes, static files, image optimizations, and .png files
    '/((?!api|_next/static|manifest.webmanifest|_next/image|.*\\.png$).*)',
  ],
};